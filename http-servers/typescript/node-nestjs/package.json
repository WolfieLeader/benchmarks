{
  "name": "nestjs-server",
  "version": "0.0.0",
  "private": true,
  "main": "dist/main.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "dev": "tsc -p tsconfig.build.json && node --enable-source-maps --watch dist/main.js",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write ./src",
    "lint": "biome lint ./src",
    "lint:fix": "biome check --fix ./src"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "cassandra-driver": "^4.9.0",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "1.0.0-rc.4",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "mongodb": "^7.4.0",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "typescript": "7.0.1-rc"
  },
  "engines": {
    "node": ">=25.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core"
    ]
  }
}
