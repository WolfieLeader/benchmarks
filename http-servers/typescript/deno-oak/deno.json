{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --allow-read src/index.ts",
    "start": "deno run --allow-net --allow-env --allow-read src/index.ts",
    "check": "deno check src/**/*.ts",
    "format": "deno fmt",
    "lint": "deno lint",
    "lint:fix": "deno lint --fix"
  },
  "imports": {
    "@oak/oak": "jsr:@oak/oak@^17.2.0",
    "cassandra-driver": "npm:cassandra-driver@^4.9.0",
    "drizzle-orm": "npm:drizzle-orm@1.0.0-rc.4",
    "drizzle-orm/node-postgres": "npm:drizzle-orm@1.0.0-rc.4/node-postgres",
    "drizzle-orm/pg-core": "npm:drizzle-orm@1.0.0-rc.4/pg-core",
    "ioredis": "npm:ioredis@^5.11.1",
    "mongodb": "npm:mongodb@^7.4.0",
    "pg": "npm:pg@^8.22.0",
    "uuid": "npm:uuid@^14.0.1",
    "zod": "npm:zod@^4.4.3"
  },
  "nodeModulesDir": "auto",
  "fmt": {
    "useTabs": false,
    "lineWidth": 120,
    "indentWidth": 2,
    "singleQuote": false,
    "proseWrap": "preserve",
    "semiColons": true,
    "trailingCommas": "never",
    "newLineKind": "auto",
    "spaceSurroundingProperties": true,
    "jsx.bracketPosition": "sameLine"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
