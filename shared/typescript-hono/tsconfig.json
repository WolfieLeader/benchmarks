{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "@bench/hono-app",
  "compilerOptions": {
    // Typecheck-only config (`tsc --noEmit`); tsdown (rolldown + oxc) owns the
    // build. `module: preserve` + `moduleResolution: bundler` let the source use
    // explicit ./module.ts specifiers (allowImportingTsExtensions) — a bundler,
    // not tsc, resolves them at build time.
    "target": "ES2024",
    "lib": ["ES2024"],
    "moduleDetection": "force",
    "module": "preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "allowJs": false,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictNullChecks": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
