{
  "name": "@bench/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write ./src",
    "lint": "biome lint ./src",
    "lint:fix": "biome check --fix ./src"
  },
  "dependencies": {
    "cassandra-driver": "^4.9.0",
    "drizzle-orm": "1.0.0-rc.4",
    "ioredis": "^5.11.1",
    "jose": "^6.1.0",
    "mongodb": "^7.4.0",
    "postgres": "^3.4.9",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "tsdown": "0.22.3",
    "typescript": "7.0.1-rc"
  },
  "engines": {
    "node": ">=25.6.0"
  }
}
