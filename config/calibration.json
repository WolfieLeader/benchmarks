{
  "$schema": "./config.schema.json",

  "benchmark": {
    "base_url": "http://localhost:8080",
    "request_timeout": "10s",
    "concurrency": 200,
    "duration_per_endpoint": "30s",
    "warmup_duration": "3s",
    "warmup_pause": "1s"
  },

  "container": {
    "cpu_limit": 4.0,
    "memory_limit": "2gb"
  },

  "databases": [],

  "endpoints": {
    "health": {
      "route": "GET /health",
      "expect": { "status": 200, "text": "OK" }
    }
  }
}
