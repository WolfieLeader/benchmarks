    {
      "name": "unknown_database_health_unavailable",
      "method": "GET",
      "path": "/db/mysql/health",
      "expect": { "status": 503, "text": "Service Unavailable" }
    },
    {
      "name": "unknown_database_create_404",
      "method": "POST",
      "path": "/db/mysql/users",
      "body": { "name": "X", "email": "x@y.com" },
      "expect": { "status": 404, "body": { "error": "not found", "details": "unknown database type: mysql" } }
    },
    {
      "name": "unknown_database_read_404",
      "method": "GET",
      "path": "/db/mysql/users/123",
      "expect": { "status": 404, "body": { "error": "not found", "details": "unknown database type: mysql" } }
    },
    {
      "name": "create_rejects_invalid_email",
      "method": "POST",
      "path": "/db/mongodb/users",
      "body": { "name": "X", "email": "not-an-email" },
      "expect": { "status": 400, "body": { "error": "invalid JSON body", "details": "$present" } }
    },
    {
      "name": "create_rejects_out_of_range_favorite_number",
      "method": "POST",
      "path": "/db/mongodb/users",
      "body": { "name": "X", "email": "x@y.com", "favoriteNumber": 101 },
      "expect": { "status": 400, "body": { "error": "invalid JSON body", "details": "$present" } }
    },
    {
      "name": "create_rejects_malformed_favorite_number_type",
      "note": "Wrong JSON type for favoriteNumber fails at decode, still surfaced as invalid JSON body.",
      "method": "POST",
      "path": "/db/mongodb/users",
      "rawBody": "{\"name\":\"X\",\"email\":\"x@y.com\",\"favoriteNumber\":\"abc\"}",
      "expect": { "status": 400, "body": { "error": "invalid JSON body", "details": "$present" } }
    },
    {
      "name": "create_rejects_empty_name",
      "method": "POST",
      "path": "/db/mongodb/users",
      "body": { "name": "", "email": "x@y.com" },
      "expect": { "status": 400, "body": { "error": "invalid JSON body", "details": "$present" } }
    },
    {
      "name": "create_rejects_malformed_json",
      "method": "POST",
      "path": "/db/mongodb/users",
      "rawBody": "{bad",
      "expect": { "status": 400, "body": { "error": "invalid JSON body", "details": "$present" } }
    },
    {
      "name": "create_rejects_case_mismatched_field_names",
      "note": "CANON: JSON field names are case-sensitive. PascalCase keys do not satisfy the required lower-case schema fields, so the required `name`/`email` fields are missing and validation fails 400 (Go json/v1's case-insensitive struct matching was the pre-v2 outlier, fixed by the json/v2 migration). Expressed via rawBody to send exact-cased keys.",
      "method": "POST",
      "path": "/db/mongodb/users",
      "rawBody": "{\"Name\":\"x\",\"Email\":\"y@conformance-suite.com\",\"FavoriteNumber\":7}",
      "expect": { "status": 400, "body": { "error": "invalid JSON body", "details": "$present" } }
    },
    {
      "name": "read_nonexistent_user_404",
      "method": "GET",
      "path": "/db/mongodb/users/000000000000000000000000",
      "expect": { "status": 404, "body": { "error": "not found", "details": "$present" } }
    }
  ]
}
