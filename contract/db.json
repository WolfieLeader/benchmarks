        { "name": "read_after_delete_404", "method": "GET", "path": "/db/cassandra/users/{id}", "expect": { "status": 404, "body": { "error": "not found", "details": "$present" } } },
        { "name": "delete_all", "method": "DELETE", "path": "/db/cassandra/users", "expect": { "status": 200, "body": { "success": true } } }
