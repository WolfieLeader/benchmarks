          "expect": { "status": 201, "body": { "id": "$id", "name": "Bob", "email": "bob@conformance-suite.com", "favoriteNumber": "$absent" } }
        },
        { "name": "delete", "method": "DELETE", "path": "/db/mongodb/users/{id}", "expect": { "status": 200, "body": { "success": true } } },
        { "name": "read_after_delete_404", "method": "GET", "path": "/db/mongodb/users/{id}", "expect": { "status": 404, "body": { "error": "not found", "details": "$present" } } },
        { "name": "delete_all", "method": "DELETE", "path": "/db/mongodb/users", "expect": { "status": 200, "body": { "success": true } } }
      ]
    },
