{
  "name": "db",
  "cases": [
    {
      "name": "health_postgres",
      "method": "GET",
      "path": "/db/postgres/health",
      "expect": { "status": 200, "headers": { "Content-Type": "text/plain" }, "text": "OK" }
    },
    {
      "name": "health_mongodb",
      "method": "GET",
      "path": "/db/mongodb/health",
      "expect": { "status": 200, "headers": { "Content-Type": "text/plain" }, "text": "OK" }
    },
    {
      "name": "health_redis",
      "method": "GET",
      "path": "/db/redis/health",
      "expect": { "status": 200, "headers": { "Content-Type": "text/plain" }, "text": "OK" }
    },
    {
      "name": "health_cassandra",
      "method": "GET",
      "path": "/db/cassandra/health",
      "expect": { "status": 200, "headers": { "Content-Type": "text/plain" }, "text": "OK" }
    },

    {
      "name": "crud_postgres",
      "flow": [
        { "name": "reset", "method": "DELETE", "path": "/db/postgres/reset", "expect": { "status": 200, "body": { "status": "ok" } } },
        {
          "name": "create",
          "method": "POST",
          "path": "/db/postgres/users",
          "body": { "name": "Alice", "email": "alice@conformance-suite.com", "favoriteNumber": 7 },
          "capture": { "id": "id" },
          "expect": { "status": 201, "body": { "id": "$id", "name": "Alice", "email": "alice@conformance-suite.com", "favoriteNumber": 7 } }
        },
        {
          "name": "read",
          "method": "GET",
          "path": "/db/postgres/users/{id}",
          "expect": { "status": 200, "body": { "id": "{id}", "name": "Alice", "email": "alice@conformance-suite.com", "favoriteNumber": 7 } }
        },
        {
          "name": "update",
          "method": "PATCH",
          "path": "/db/postgres/users/{id}",
          "body": { "name": "Alice Updated" },
          "expect": { "status": 200, "body": { "id": "{id}", "name": "Alice Updated", "email": "alice@conformance-suite.com", "favoriteNumber": 7 } }
        },
        {
          "name": "create_without_favorite_number",
          "method": "POST",
          "path": "/db/postgres/users",
          "body": { "name": "Bob", "email": "bob@conformance-suite.com" },
          "expect": { "status": 201, "body": { "id": "$id", "name": "Bob", "email": "bob@conformance-suite.com", "favoriteNumber": "$absent" } }
        },
        { "name": "delete", "method": "DELETE", "path": "/db/postgres/users/{id}", "expect": { "status": 200, "body": { "success": true } } },
        { "name": "read_after_delete_404", "method": "GET", "path": "/db/postgres/users/{id}", "expect": { "status": 404, "body": { "error": "not found", "details": "$present" } } },
        { "name": "delete_all", "method": "DELETE", "path": "/db/postgres/users", "expect": { "status": 200, "body": { "success": true } } }
      ]
    },
