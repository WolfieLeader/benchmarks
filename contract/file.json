{
  "name": "file",
  "cases": [
    {
      "name": "file_upload_happy_path",
      "method": "POST",
      "path": "/params/file",
      "multipart": {
        "file": { "field": "file", "filename": "test.txt", "contentType": "text/plain", "source": "test.txt" }
      },
      "expect": { "status": 200, "body": { "filename": "test.txt", "size": 14, "content": "Hello, World!\n" } }
    },
    {
      "name": "file_upload_multiline",
      "method": "POST",
      "path": "/params/file",
      "multipart": {
        "file": { "field": "file", "filename": "multi.txt", "contentType": "text/plain", "source": "multi.txt" }
      },
      "expect": { "status": 200, "body": { "filename": "multi.txt", "size": 21, "content": "Line 1\nLine 2\nLine 3\n" } }
    },
    {
      "name": "file_rejects_non_multipart_content_type",
      "method": "POST",
      "path": "/params/file",
      "body": { "not": "multipart" },
      "expect": {
        "status": 400,
        "headers": { "Content-Type": "application/json" },
        "body": { "error": "invalid multipart form data", "details": "expected content-type: multipart/form-data" }
      }
    },
    {
      "name": "file_rejects_missing_file_field",
      "method": "POST",
      "path": "/params/file",
      "multipart": { "fields": { "notafile": "x" } },
      "expect": { "status": 400, "headers": { "Content-Type": "application/json" }, "body": { "error": "file not found in form data", "details": "$present" } }
    },
    {
      "name": "file_rejects_wrong_declared_content_type",
      "note": "Part declares image/png -> rejected on the declared type.",
      "method": "POST",
      "path": "/params/file",
      "multipart": {
        "file": { "field": "file", "filename": "logo.png", "contentType": "image/png", "text": "still just text" }
      },
      "expect": { "status": 415, "headers": { "Content-Type": "application/json" }, "body": { "error": "only text/plain files are allowed", "details": "$optional" } }
    },
    {
      "name": "file_anti_sniffing_binary_lying_as_text",
      "note": "SECURITY: binary content declared as text/plain must still be rejected by content inspection, not trusted by the header.",
      "method": "POST",
      "path": "/params/file",
      "multipart": {
        "file": { "field": "file", "filename": "sneaky.txt", "contentType": "text/plain", "source": "binary.bin" }
      },
      "expect": { "status": 415, "headers": { "Content-Type": "application/json" }, "body": { "error": "file does not look like plain text", "details": "$optional" } }
    },
    {
      "name": "file_rejects_sniffed_binary_without_declared_type",
      "note": "SECURITY: no declared content-type; server sniffs the bytes and rejects non-text.",
      "method": "POST",
      "path": "/params/file",
      "multipart": {
        "file": { "field": "file", "filename": "blob", "source": "binary.bin" }
      },
      "expect": { "status": 415, "headers": { "Content-Type": "application/json" }, "body": { "error": "only text/plain files are allowed", "details": "$optional" } }
    },
    {
      "name": "file_rejects_nul_after_sniff_window",
      "note": "SECURITY (full-body NUL scan, canon per servers/go-stdlib/internal/routes/params.go): the 512-byte window is used ONLY for MIME sniffing; the NUL check scans the ENTIRE body. This fixture is 600 bytes of clean ASCII (so the sniff window sees text/plain and the declared text/plain passes) followed by a NUL at offset 600 and more text. A server that only inspects the first 512 bytes for NUL would wrongly accept it. Must be rejected 415 as not-plain-text.",
      "method": "POST",
      "path": "/params/file",
      "multipart": {
        "file": { "field": "file", "filename": "late-nul.txt", "contentType": "text/plain", "source": "text-with-late-nul.txt" }
      },
      "expect": { "status": 415, "headers": { "Content-Type": "application/json" }, "body": { "error": "file does not look like plain text", "details": "$optional" } }
    },
    {
      "name": "file_rejects_oversized_payload",
      "note": "SECURITY: >1MiB payload is synthesized by the runner (not committed) and must be rejected 413.",
      "method": "POST",
      "path": "/params/file",
      "multipart": {
        "file": { "field": "file", "filename": "big.txt", "contentType": "text/plain", "sizeBytes": 1100000 }
      },
      "expect": { "status": 413, "headers": { "Content-Type": "application/json" }, "body": { "error": "file size exceeds limit", "details": "$optional" } }
    }
  ]
}
