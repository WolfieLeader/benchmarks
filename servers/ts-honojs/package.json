{
  "name": "server-honojs",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write ./src",
    "lint": "biome lint ./src",
    "lint:fix": "biome check --fix ./src"
  },
  "dependencies": {
    "@bench/hono-app": "workspace:*",
    "@bench/shared": "workspace:*",
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "7.0.1-rc"
  },
  "engines": {
    "node": ">=25.6.0"
  }
}
