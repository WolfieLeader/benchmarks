{
  "name": "bun-elysia",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "format": "biome format --write ./src",
    "lint": "biome lint ./src",
    "lint:fix": "biome check  --fix ./src"
  },
  "dependencies": {
    "cassandra-driver": "^4.9.0",
    "drizzle-orm": "1.0.0-rc.4",
    "elysia": "1.4.29",
