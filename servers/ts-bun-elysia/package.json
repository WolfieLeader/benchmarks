    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "typescript": "7.0.1-rc"
  },
  "engines": {
    "bun": ">=1.3.8"
  },
  "overrides": {
    "bson": "7.2.0"
