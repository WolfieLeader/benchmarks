{
  "name": "honojs-server",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "typecheck": "bunx tsc --noEmit",
    "format": "biome format --write ./src",
    "lint": "biome lint ./src",
    "lint:fix": "biome check --fix ./src"
  },
  "dependencies": {
    "@bench/hono-app": "workspace:*",
    "@bench/shared": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bun": "^1.3.14",
    "typescript": "7.0.1-rc"
  },
  "engines": {
    "bun": ">=1.3.8"
  }
}
